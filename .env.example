# ─────────────────────────────────────────────────────────────────────────────
# Pixera — VPS environment variables
# Copy this file to .env, fill in every value, then run: docker compose up -d
# NEVER commit the real .env file — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
# These must be DNS A records pointing at this VPS before you start Caddy.
# Caddy will automatically provision TLS certificates via Let's Encrypt.
API_DOMAIN=api.yourdomain.com
AUTH_DOMAIN=auth.yourdomain.com
STORAGE_DOMAIN=storage.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pixera
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pixera

# ── MinIO (S3-compatible file storage) ────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_BUCKET=pixera

# ── Keycloak (identity provider) ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password
KEYCLOAK_REALM=pixera
KEYCLOAK_CLIENT_ID=pixera-admin

# ── GitHub (feedback → issues) ────────────────────────────────────────────────
# Personal access token with public_repo scope.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/pixera

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL and any custom domain.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com
