# ─────────────────────────────────────────────────────────────────────────────
# Pixera — VPS environment variables
# Copy this file to .env, fill in every value, then run: docker compose up -d
# NEVER commit the real .env file — it is git-ignored.
#
# Free subdomain option (no domain purchase needed):
#   Sign up at https://www.duckdns.org, create a subdomain e.g. "pixera-demo",
#   set the IP to your VPS IP, then use pixera-demo.duckdns.org below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
# Must resolve to this VPS IP before starting Caddy (Caddy auto-provisions HTTPS).
# DuckDNS example: pixera-demo.duckdns.org
API_DOMAIN=pixera-api.duckdns.org
AUTH_DOMAIN=pixera-auth.duckdns.org
STORAGE_DOMAIN=pixera-storage.duckdns.org

# ── Auth mode ─────────────────────────────────────────────────────────────────
# true  = skip Keycloak, all admin requests are auto-authenticated (demo/dev)
# false = validate real Keycloak JWTs (production)
AUTH_BYPASS=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=pixera
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pixera

# ── MinIO (S3-compatible file storage) ────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_BUCKET=pixera

# ── Keycloak (identity provider — only needed when AUTH_BYPASS=false) ─────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong-password
KEYCLOAK_REALM=pixera
KEYCLOAK_CLIENT_ID=pixera-admin

# ── GitHub (feedback → issues) ────────────────────────────────────────────────
# Personal access token with public_repo scope.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/pixera

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL (shown after first Vercel deploy).
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
