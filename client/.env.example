VITE_USE_LOCAL_DATA=false
VITE_API_URL=http://localhost:5000

# Keycloak — required when accessing /admin in staging/production
# Set VITE_KEYCLOAK_DEV_BYPASS=true locally to skip Keycloak entirely (mirrors the backend DevBypassAuthHandler)
VITE_KEYCLOAK_DEV_BYPASS=false
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=pixera
VITE_KEYCLOAK_CLIENT_ID=pixera-admin
